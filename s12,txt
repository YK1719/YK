Q2. Write a Python program that:
a) Retrieves current local time and UTC time.
b) Prints the current time using ctime() and gmtime().
c) Accepts a date-time string input in the format DD-MM-YYYY HH:MM:SS.
d) Parses the string using strptime() and formats it back using strftime() and display it in two
custom formats.

import time
from datetime import datetime

# a) Retrieve current local time and UTC time
local_time = time.localtime()
utc_time = time.gmtime()

print("Current Local Time (struct_time):", local_time)
print("Current UTC Time (struct_time):", utc_time)
print("\n")

# b) Print current time using ctime() and gmtime()
print("Current Local Time (ctime):", time.ctime())
print("Current UTC Time (gmtime + ctime):", time.asctime(utc_time))
print("\n")

# c) Accept date-time string input
date_input = input("Enter date-time (DD-MM-YYYY HH:MM:SS): ")

# d) Parse string using strptime()
parsed_datetime = datetime.strptime(date_input, "%d-%m-%Y %H:%M:%S")

# Format back using strftime() in two custom formats
format1 = parsed_datetime.strftime("%A, %d %B %Y, %I:%M %p")  # Example: Friday, 15 March 2024, 08:30 PM
format2 = parsed_datetime.strftime("%d/%m/%Y %H:%M:%S")       # Example: 15/03/2024 20:30:00

print("\nParsed Date-Time in Custom Format 1:", format1)
print("Parsed Date-Time in Custom Format 2:", format2)

