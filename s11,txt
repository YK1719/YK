Create a Flask application that allows users to add and view tasks. The application should have: a) A form to add a task (task_name). b) Store tasks in a SQL server database. c) Display all tasks below the form.
SQL DATABASE open
CREATE DATABASE TaskDB;

USE TaskDB;

CREATE TABLE Tasks (
id INT IDENTITY(1,1) PRIMARY KEY,
task_name VARCHAR(255)
);

App.py
from flask import Flask, render_template, request, redirect
import pyodbc

app = Flask(__name__)

# SQL Server Connection
conn = pyodbc.connect(
    "Driver={SQL Server};"
    "Server=YOUR_SERVER_NAME;"
    "Database=TaskDB;"
    "Trusted_Connection=yes;"
)
cursor = conn.cursor()

@app.route('/', methods=['GET', 'POST'])
def index():
    if request.method == 'POST':
        task_name = request.form['task_name']

        # Insert task into database
        cursor.execute("INSERT INTO Tasks (task_name) VALUES (?)", task_name)
        conn.commit()

        return redirect('/')

    # Fetch all tasks
    cursor.execute("SELECT * FROM Tasks")
    tasks = cursor.fetchall()

    return render_template('index.html', tasks=tasks)

if __name__ == '__main__':
    app.run(debug=True)

